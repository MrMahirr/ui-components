# ==========================================
# Component Manager - Monorepo .gitignore
# ==========================================

# --- Node / Dependency Directories ---
node_modules/
**/node_modules/

# --- Build & Compiled Output ---
dist/
**/dist/
dist-ssr/
**/dist-ssr/
build/
**/build/
coverage/
**/coverage/
/.nyc_output

# --- Environment and Secrets ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
**/.env.*.local
*.pem
*.key

# --- IDEs and Editors ---
# JetBrains / IntelliJ IDEA
.idea/
**/.idea/
*.iml
*.iws

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
**/ .vscode/*

# General Editors & Backups
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# --- Logs & Diagnostics ---
logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# --- OS / System Files ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini

# --- Temp & Runtime Files ---
.temp/
.tmp/
.eslintcache
pids
*.pid
*.seed
*.pid.lock
